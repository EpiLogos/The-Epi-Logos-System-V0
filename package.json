{
  "name": "epi-logos-system",
  "version": "0.1.0",
  "description": "The Epi-Logos System V0.1 - A tri-laminar architecture for wisdom synthesis",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\" \"npm run dev:agentic\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "docker-compose up -d qdrant && source .venv/bin/activate && python -m uvicorn backend.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:agentic": "source .venv/bin/activate && python -m uvicorn agentic.main:app --reload --host 0.0.0.0 --port 8001",
    "dev:mcp": "source .venv/bin/activate && python -m agentic.mcp_servers.bimba_pratibimba_server --transport sse",
    "stop:mcp": "pkill -f 'agentic.mcp_servers.bimba_pratibimba_server' || echo 'MCP server not running'",
    "build": "npm run build:packages && npm run build:frontend",
    "build:packages": "npm run build --workspaces --if-present",
    "build:frontend": "cd frontend && npm run build",
    "test": "npm run test:frontend && npm run test:backend && npm run test:e2e",
    "test:frontend": "cd frontend && npm run test",
    "test:backend": "source .venv/bin/activate && PYTHONPATH=.:backend python -m pytest -c backend/pytest.ini",
    "test:agentic": "source .venv/bin/activate && cd agentic && python -m pytest",
    "test:e2e": "cd tests/e2e && npx playwright test",
    "test:structure": "python3 -m pytest tests/project-genesis/structure/ -v",
    "lint": "npm run lint:frontend && npm run lint:backend && npm run lint:agentic",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:backend": "source .venv/bin/activate && cd backend && ruff check .",
    "lint:agentic": "source .venv/bin/activate && cd agentic && ruff check .",
    "format": "npm run format:frontend && npm run format:backend && npm run format:agentic",
    "format:frontend": "cd frontend && npm run format",
    "format:backend": "source .venv/bin/activate && cd backend && black . && ruff format .",
    "format:agentic": "source .venv/bin/activate && cd agentic && black . && ruff format .",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "qdrant:start": "docker-compose up -d qdrant",
    "qdrant:stop": "docker-compose stop qdrant",
    "qdrant:logs": "docker-compose logs -f qdrant",
    "qdrant:restart": "docker-compose restart qdrant",
    "docker:prod:build": "docker-compose -f docker-compose.prod.yml build",
    "docker:prod:up": "docker-compose -f docker-compose.prod.yml up -d",
    "docker:prod:down": "docker-compose -f docker-compose.prod.yml down",
    "docker:prod:logs": "docker-compose -f docker-compose.prod.yml logs -f",
    "setup": "./scripts/dev-start.sh",
    "setup:full": "npm install && npm run setup:python && npm run setup:hooks",
    "setup:python": "./scripts/setup-dev-environment.sh",
    "setup:hooks": "pre-commit install",
    "start": "./scripts/dev-quick-start.sh",
    "start:full": "./scripts/dev-start.sh",
    "stop": "./scripts/dev-stop.sh",
    "clean": "./scripts/dev-clean.sh",
    "clean:deps": "rm -rf node_modules packages/*/node_modules frontend/node_modules",
    "clean:build": "rm -rf packages/*/dist frontend/.next backend/__pycache__ agentic/__pycache__",
    "check": "npm run type-check && npm run lint",
    "type-check": "npm run type-check --workspaces --if-present",
    "fix": "npm run format && npm run lint:fix",
    "lint:fix": "npm run lint:frontend -- --fix",
    "ci": "npm run check && npm run test && npm run build",
    "optimize:images": "node scripts/optimize-images.mjs",
    "restore:images": "node scripts/restore-images.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "concurrently": "^9.1.0",
    "sharp": "^0.33.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0",
    "python": ">=3.13.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/epi-logos/epi-logos-system.git"
  },
  "keywords": [
    "wisdom-synthesis",
    "tri-laminar-architecture",
    "graph-database",
    "agentic-ai",
    "knowledge-management"
  ],
  "author": "Epi-Logos Team",
  "license": "MIT",
  "dependencies": {
    "dexie": "^4.2.1",
    "dexie-react-hooks": "^4.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "optionalDependencies": {
    "lightningcss-darwin-arm64": "^1.30.2",
    "lightningcss-linux-x64-gnu": "^1.30.2",
    "lightningcss-linux-x64-musl": "^1.30.2"
  }
}
