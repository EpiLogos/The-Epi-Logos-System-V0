@import "tailwindcss";
@import "@fontsource/jetbrains-mono/400.css";
@import "@fontsource/jetbrains-mono/700.css";
/* VERIFIED: style.css import permanently removed - components are pure Tailwind v4 */

* {
  font-family: 'JetBrains Mono', monospace !important;
}

html, body {
  background-color: #f5f5f5 !important;
  margin: 0;
  padding: 0;
}

/* ESSENTIAL EPI-LOGOS COORDINATE COLORS - PRESERVED */
@theme {
  /* Container Configuration */
  --container-center: true;
  --container-padding: 2rem;
  --breakpoint-2xl: 87.5rem; /* 1400px */

  /* Font Families - JetBrains Mono */
  --font-sans: 'JetBrains Mono', monospace;
  --font-heading: 'JetBrains Mono', monospace;
  --font-mono: 'JetBrains Mono', monospace;

  /* NEW UI SYSTEM COLORS */
  --color-ui-gray: #f5f5f5;
  --color-ui-panel: #090a09;
  --color-ui-coord-text: #666666;

  /* Border Radius */
  --radius-lg: var(--radius);
  --radius-md: calc(var(--radius) - 2px);
  --radius-sm: calc(var(--radius) - 4px);

  /* Custom Colors - Using HSL format for Tailwind v4 */
  --color-border: hsl(214.3 31.8% 91.4%);
  --color-input: hsl(214.3 31.8% 91.4%);
  --color-ring: hsl(222.2 84% 4.9%);
  --color-background: hsl(0 0% 100%);
  --color-foreground: hsl(222.2 84% 4.9%);

  --color-primary: hsl(222.2 47.4% 11.2%);
  --color-primary-foreground: hsl(210 40% 98%);

  --color-secondary: hsl(210 40% 96%);
  --color-secondary-foreground: hsl(222.2 47.4% 11.2%);

  --color-destructive: hsl(0 84.2% 60.2%);
  --color-destructive-foreground: hsl(210 40% 98%);

  --color-muted: hsl(210 40% 96%);
  --color-muted-foreground: hsl(215.4 16.3% 46.9%);

  --color-accent: hsl(210 40% 96%);
  --color-accent-foreground: hsl(222.2 47.4% 11.2%);

  --color-popover: hsl(0 0% 100%);
  --color-popover-foreground: hsl(222.2 84% 4.9%);

  --color-card: hsl(0 0% 100%);
  --color-card-foreground: hsl(222.2 84% 4.9%);

  /* Error Component Colors */
  --color-error: hsl(0 84.2% 60.2%);
  --color-error-foreground: hsl(210 40% 98%);
  --color-warning: hsl(38 92% 50%);
  --color-warning-foreground: hsl(48 96% 89%);
  --color-success: hsl(142 76% 36%);
  --color-success-foreground: hsl(138 76% 97%);

  /* Custom Animations */
  --animate-accordion-down: accordion-down 0.2s ease-out;
  --animate-accordion-up: accordion-up 0.2s ease-out;
  --animate-pulse-slow: pulse-slow 3s ease-in-out infinite;
  --animate-slideIn: slideIn 150ms cubic-bezier(0.16, 1, 0.3, 1);
  --animate-slideOut: slideOut 150ms cubic-bezier(0.16, 1, 0.3, 1);
  --animate-swipeOut: swipeOut 100ms ease-out;
  --animate-fadeIn: fadeIn 150ms ease-in;
  --animate-fadeOut: fadeOut 150ms ease-out;

  /* Keyframes */
  @keyframes accordion-down {
    from { height: 0; }
    to { height: var(--radix-accordion-content-height); }
  }

  @keyframes accordion-up {
    from { height: var(--radix-accordion-content-height); }
    to { height: 0; }
  }

  @keyframes pulse-slow {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* Error Component Animations */
  @keyframes slideIn {
    from {
      transform: translateX(calc(100% + 1rem));
    }
    to {
      transform: translateX(0);
    }
  }

  @keyframes slideOut {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(calc(100% + 1rem));
    }
  }

  @keyframes swipeOut {
    from {
      transform: translateX(var(--radix-toast-swipe-move-x));
    }
    to {
      transform: translateX(calc(100% + 1rem));
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes fadeOut {
    from {
      opacity: 1;
    }
    to {
      opacity: 0;
    }
  }
}

/* TAILWIND V4 CUSTOM UTILITIES - PROJECT DETAILS */
@utility project-details-label {
  font-size: 11px;
  color: #666;
  text-transform: uppercase;
  letter-spacing: 1px;
  min-width: 90px;
  flex-shrink: 0;
}

@utility project-details-value {
  font-size: 11px;
  color: #333;
  font-weight: normal;
  letter-spacing: 1px;
}

@utility project-details-container {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-bottom: 20px;
  padding-top: 10px;
}

@utility project-details-item {
  display: flex;
  justify-content: flex-start;
  gap: 30px;
  width: 75%;
}

/* TAILWIND V4 COORDINATE TEXT UTILITIES - CONVERTED FROM ORIGINAL CSS */

/* Base coordinate text overlay - FIXED positioning to prevent container shifts */
@utility coordinate-text-overlay {
  position: fixed;
  bottom: -20px;
  right: 40px;
  font-size: 90px;
  color: #666666;
  letter-spacing: -3px;
  font-weight: bold;
  transform: scaleX(0.9);
  transform-origin: right;
  opacity: 0;
  filter: blur(10px);
  transition: opacity 800ms ease, filter 800ms ease;
  pointer-events: none;
  z-index: 10;
}

/* Visible state - from .coordinate-text-overlay.visible */
@utility coordinate-text-overlay-visible {
  opacity: 1;
  filter: blur(0px);
}

/* Paramasiva coordinate positioning - from .coordinate-text-overlay.paramasiva-coordinate */
@utility coordinate-text-paramasiva {
  bottom: 20px;
  right: 40px;
  z-index: 5;
  transition: opacity 800ms ease, filter 800ms ease, bottom 600ms cubic-bezier(0.25, 0.1, 0.25, 1);
}

/* Paramasiva visible state - from .coordinate-text-overlay.paramasiva-coordinate.visible */
@utility coordinate-text-paramasiva-visible {
  opacity: 1;
  filter: blur(0px);
  bottom: 20px;
}

/* Original panel coordinate text for grid pages */
@utility coordinate-text {
  position: absolute;
  bottom: 30px;
  right: 40px;
  font-size: 72px;
  color: #666666;
  letter-spacing: 0px;
  font-weight: bold;
  transform: scaleX(0.9);
  transform-origin: right;
  pointer-events: none;
  z-index: 10;
  opacity: 0;
  filter: blur(10px);
  transition: opacity 800ms ease, filter 800ms ease;
}

@utility coordinate-text-visible {
  opacity: 1;
  filter: blur(0px);
}

/* TAILWIND V4 CUSTOM VARIANT - PAGE TWO WITH OVERRIDES */
@custom-variant page-two (&.page-two-content);

/* Page two specific styles using @variant directive */
@variant page-two {
  .project-details-label {
    font-size: 9.9px;
    min-width: 120px;
  }

  .project-details-value {
    font-size: 9.4px;
    letter-spacing: 0.5px;
    line-height: 1.357;
  }

  .project-details-container {
    gap: 2px;
  }

  h3 {
    margin-bottom: 5px;
  }
}

/* TAILWIND V4 CUSTOM UTILITIES - CONVERTED FROM ORIGINAL CSS */
@utility page-container-expanded {
  height: calc(60vh + 35vh);
  z-index: 1000;
  /* REMOVED: Base element now handles transition */
}

/* QUATERNAL LOGIC SPECIFIC MODAL EXPANSION */
@utility page-container-quaternal-expanded {
  height: calc(100vh - 40px);
  z-index: 1000;
  /* Full height expansion for quaternal logic modal */
}

@utility page-two-left-expanded {
  height: 100%;
  padding: 40px;
  transition: height 0.5s ease-out, padding 0.5s ease-out;
}

@utility page-two-children-expanded {
  flex-shrink: 0;
}

/* PNG SMOOTH TRANSITION SYSTEM - Base Transition + State Pattern */

/* BASE TRANSITION - Always applied for smooth bidirectional transitions */
@utility panel-two-png-smooth-transition {
  transition: transform 800ms cubic-bezier(0.4, 0, 0.2, 1), filter 300ms ease-out;
}

/* STATE UTILITIES - Transform values only, no transition declarations */
@utility panel-two-png-bottom-state {
  transform: scale(0.7) translateY(5px);
}

@utility panel-two-png-modal-state {
  filter: contrast(3.5) brightness(1.6);
  transform: translateY(10px);
}

@utility particles-canvas-expanded {
  filter: blur(4px);
}

/* MODAL EXPANSION UTILITIES - CONVERTED FROM .page-container.expanded CSS */
@utility modal-expanded-debug-top-left {
  top: 40px;
  left: 40px;
  transform: scale(1.1);
}

@utility modal-expanded-debug-top-right {
  top: 40px;
  right: 40px;
  transform: scale(1.1);
}

@utility modal-expanded-debug-bottom {
  bottom: 60px;
  left: 50%;
  transform: translateX(-50%) translateY(0) scale(1.1);
  width: 70%;
}

/* DEBUG MODAL POSITIONING - EXACT ORIGINAL VALUES */
@utility debug-modal-base {
  position: absolute;
  background: none;
  border: none;
  padding: 15px;
  color: white;
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px;
  font-weight: normal;
  line-height: 1.3;
  opacity: 0;
  transition: opacity 0.3s ease-in-out, transform 0.5s ease-out, top 0.5s ease-out, bottom 0.5s ease-out, left 0.5s ease-out, right 0.5s ease-out, width 0.5s ease-out;
  pointer-events: none;
  z-index: 100;
  text-shadow: 1px 1px 2px rgba(0,0,0,0.8);
}

@utility debug-modal-top-left-normal {
  top: 20px;
  left: 20px;
  width: 280px;
  height: 120px;
  transform: translateY(-10px);
}

@utility debug-modal-top-right-normal {
  top: 20px;
  right: 20px;
  width: 280px;
  height: 140px;
  transform: translateY(-10px);
}

@utility debug-modal-bottom-normal {
  bottom: 40px;
  left: 50%;
  transform: translateX(-50%) translateY(10px) scale(1);
  width: 60%;
  height: 100px;
}

@utility debug-modal-visible {
  opacity: 1;
}

@utility debug-modal-top-visible {
  opacity: 1;
  transform: translateY(0);
}

@utility debug-modal-bottom-visible {
  opacity: 1;
  transform: translateX(-50%) translateY(0) scale(1);
}

@utility debug-modal-top-left-expanded {
  top: 40px;
  left: 40px;
  transform: scale(1.1);
}

@utility debug-modal-top-right-expanded {
  top: 40px;
  right: 40px;
  transform: scale(1.1);
}

@utility debug-modal-bottom-expanded {
  bottom: 60px;
  left: 50%;
  transform: translateX(-50%) translateY(0) scale(1.1);
  width: 70%;
}

/* PAGE TRANSITION EFFECTS - EXACT ORIGINAL LOGIC */
@utility page-content-transitioning {
  pointer-events: none;
}

@utility page-content-blurring {
  filter: blur(6px);
  transition: filter 350ms ease;
}

@utility page-content-active {
  opacity: 1;
  filter: blur(0px);
  transition: opacity 350ms ease, filter 350ms ease;
}

@utility page-content-inactive {
  opacity: 0;
  pointer-events: none;
  transition: opacity 350ms ease;
}

/* QL IMAGE POSITIONING - FOR PANEL 1 ABSOLUTE LAYOUT */
@utility ql-image-positioning {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: right center;
  z-index: 2;
}

/* QL IMAGE FADE IN - ANIMATION ONLY, NO POSITIONING */
@utility ql-image-fade-in {
  opacity: 0;
  animation: imageContentFadeIn 1.5s ease-in-out 0.8s forwards;
}

/* QL IMAGE LOADED STATE - APPLIED AFTER FADE-IN COMPLETES */
@utility ql-image-loaded {
  animation: none !important;
  opacity: 0.45 !important;  /* Force override container opacity */
  transition: opacity 300ms ease;
}

/* SEPARATED: PNG IMAGE HOVER - INDEPENDENT OF MODAL STATE */
@utility ql-image-hover {
  &:hover {
    opacity: 0.85 !important;  /* Force override container opacity */
  }
}

/* QL IMAGE TRANSITION STATES - FADE OUT DURING PAGE TRANSITIONS */
@utility ql-image-transition-out {
  opacity: 0 !important;
  transition: opacity 400ms ease;
}

@keyframes imageContentFadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 0.45;
  }
}

/* UNIFIED TEXT GROUP ANIMATION - PRESERVES EXISTING POSITIONING */
@utility geometry-text-unified {
  transition: transform 300ms ease-out;
}

@utility geometry-text-unified-expanded {
  transform: scale(0.9);
}

/* PNG SCALE-DOWN ANIMATION FOR MODAL COLLAPSE */
@utility png-scale-down {
  transition: transform 700ms ease-out;
}

@utility png-scale-down-active {
  transform: scale(0.8);
}

/* EPI PANEL SMOOTH TRANSITION SYSTEM */
@utility epi-panel-smooth-transition {
  transition: width 1200ms cubic-bezier(0.19, 1, 0.22, 1) 800ms,
              height 1000ms cubic-bezier(0.19, 1, 0.22, 1) 1300ms,
              margin 600ms cubic-bezier(0.19, 1, 0.22, 1) 800ms,
              opacity 600ms ease-out,
              border-color 300ms ease-in-out;
  transform-origin: bottom center;
}

/* PARAMASIVA IMAGE TRANSITION */
@utility paramasiva-image-transition {
  transition: top 600ms cubic-bezier(0.19, 1, 0.22, 1) 2200ms,
              left 600ms cubic-bezier(0.19, 1, 0.22, 1) 2200ms,
              width 600ms cubic-bezier(0.19, 1, 0.22, 1) 2200ms,
              height 600ms cubic-bezier(0.19, 1, 0.22, 1) 2200ms,
              transform 600ms cubic-bezier(0.19, 1, 0.22, 1) 2200ms,
              opacity 300ms ease,
              filter 300ms ease,
              scale 300ms ease;
}

/* CAROUSEL FADE-IN UTILITIES */
@utility carousel-fade-in-delayed {
  opacity: 100;
  pointer-events: auto;
  transition: opacity 800ms ease-out 400ms, pointer-events 0ms ease-out 400ms;
}

@utility carousel-fade-out {
  opacity: 0;
  pointer-events: none;
  transition: opacity 800ms ease-out, pointer-events 0ms ease-out 800ms;
}

/* WAVE FADE OUT QUICK */
@utility wave-fade-out-quick {
  opacity: 0;
  transition: opacity 200ms ease;
}

/* SCROLLABLE TEXT POSITIONING */
@utility scrollable-text-positioning {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  width: 100%;
  padding-right: 11px;
}

@utility max-height-scrollable-default {
  max-height: calc(100vh - 180px);
}

/* EXPANSION SQUARE POSITION */
@utility expansion-square-position {
  position: absolute !important;
  top: 80px !important;
  right: 100px !important;
  z-index: 10 !important;
}

/* INVISIBLE SCROLLBAR */
@utility scrollbar-thin-custom {
  scroll-behavior: smooth;

  &::-webkit-scrollbar {
    width: 0px;
    height: 0px;
  }
}

@layer base {
  * {
    font-family: 'JetBrains Mono', monospace !important;
    border-color: var(--color-border);
  }
  body {
    background-color: var(--color-ui-gray);
    color: var(--color-foreground);
  }

  /* Typography - All elements use JetBrains Mono */
  h1, h2, h3, h4, h5, h6 {
    font-family: 'JetBrains Mono', monospace;
    color: var(--color-foreground);
  }

  /* Body text uses JetBrains Mono */
  p, span, div, a, li, td, th, label, input, textarea, button {
    font-family: 'JetBrains Mono', monospace;
    color: var(--color-foreground);
  }
}