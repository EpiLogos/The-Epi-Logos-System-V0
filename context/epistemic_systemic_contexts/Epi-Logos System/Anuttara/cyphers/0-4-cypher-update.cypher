// Relationship to #1-3-4 (Spanda Contextual Expression - 0/1 Development Process)
MATCH (anuttara_4 {bimbaCoordinate: '#0-4'}),
      (spanda_contextual {bimbaCoordinate: '#1-3-4'})

MERGE (anuttara_4)-[:PROVIDES_CONTEXTUAL_FOUNDATION_FOR {
  foundationType: 'QL Context Frame Nesting for 0/1 Development',
  contextualRole: 'Supplies the archetypal matrix from which the 0/1 element can undergo its developmental process to achieve 100% identity completion',
  nestingFunction: 'Provides the QL context frame nesting structure that enables Spanda\'s contextual expression rather than remaining as pure implicate flow',
  developmentalSupport: 'The holographic matrix containing the complete potential for contextual frameworks enables the 0/1 element to develop through progressive context frame integration',
  spandaActualization: 'Transforms Spanda from archetypal seed in the genetic sequence into contextually expressed developmental dynamic',
  processualGrounding: 'Establishes the foundational context frames necessary for the 0/1 element\'s journey from pure potential to 100% actualized identity',
  architecturalSignificance: 'Without this contextual foundation, Spanda would remain implicit - this relationship makes contextual expression possible'
}]->(spanda_contextual);

// Relationship to #1-4 (Paramasiva QL Flowering Stage)
MATCH (anuttara_4 {bimbaCoordinate: '#0-4'}),
      (paramasiva_flowering {bimbaCoordinate: '#1-4'})

MERGE (anuttara_4)-[:ENABLES_QL_FLOWERING_THROUGH {
  floweringType: 'Holographic Potential to Explicit Operational Reality',
  foundationalRole: 'The complete logical architecture held in unmanifest potential becomes the explicit structural/processual framework in Paramasiva\'s flowering stage',
  formalizationProcess: 'Context frames arising from Anuttara\'s ground are formalized into the complete QL operational system',
  architecturalTransmission: 'The nested (4.0/1-4/5) structure provides the archetypal template by which Paramasiva\'s QL flowering is made practical and operational, deepening the unification of Anuttara and Paramasiva.',
  potentialActualization: 'The "operating system held in memory" becomes the "machine that runs the code" - blueprint becomes operational reality',
  universalOperatingSystem: 'Quaternal Logic nested within its own source in Anuttara becomes the universal operating system actualized in Paramasiva',
  geneticExpression: 'The genetic sequence of reality expressed here becomes the living, functional QL framework in Paramasiva\'s flowering',
  holographicManifestaton: 'The holographic matrix containing QL potential manifests as the explicit, operational QL architecture'
}]->(paramasiva_flowering);

// Relationship to #1-2 (Ananda Vortex)
MATCH (anuttara_4 {bimbaCoordinate: '#0-4'}),
      (ananda_vortex {bimbaCoordinate: '#1-2'})

MERGE (anuttara_4)-[:SOURCES_HARMONIC_VORTEX_THROUGH {
  harmonicType: 'Sat-Ananda Blissful Recognition Generating Vortex Dynamics',
  anandaConnection: 'The bliss (Ananda) of perfect recognition of holographic wholeness generates the harmonic vortex patterns',
  vortexGenesis: 'The aesthetic and spiritual joy of perceiving perfect order creates the mathematical vortex dynamics that organize archetypal patterns',
  silentMusicManifestaton: 'The "silent music of the spheres before the first note is played" becomes the actual vortex harmonics of Ananda',
  perfectOrderRealization: 'The blissful recognition that all conflicts and dualities are held in harmonious pre-manifest unity generates the vortex organizational patterns',
  holographicHarmonics: 'The holographic matrix containing perfect integration manifests as the specific vortex mathematics that create harmonic coherence',
  cosmicJoyExpression: 'The cosmic mind\'s quiet self-awareness contemplating its own infinite potential expresses as the dynamic joy of Ananda vortex',
  endInBeginningVision: 'The bliss of "seeing the end in the beginning" generates the recursive, self-referential vortex patterns that organize reality',
  harmonicBlueprint: 'The perfect, self-contained potential provides the harmonic template from which all vortex dynamics emerge'
}]->(ananda_vortex);

// Return confirmation
RETURN 'Direct relationships from Anuttara #0-4 successfully established' as status,
       'Contextual foundation for Spanda development connected' as spandaConnection,
       'QL flowering enablement relationship created' as paramasivaConnection,
       'Harmonic vortex sourcing relationship established' as anandaConnection;