%%{init: {
  'theme': 'light',
  'themeVariables': {
    'primaryColor': '#059669',
    'primaryTextColor': '#000000',
    'primaryBorderColor': '#047857',
    'lineColor': '#6b7280',
    'secondaryColor': '#f3f4f6',
    'tertiaryColor': '#e5e7eb'
  },
  'flowchart': {
    'rankdir': 'TB',
    'nodeSpacing': 60,
    'rankSpacing': 80,
    'curve': 'basis',
    'useMaxWidth': true,
    'htmlLabels': true
  }
}}%%

graph TB
    %% Service Integration Patterns Across Trilaminar Architecture
    
    subgraph "Frontend Service Integration (Port 3000)"
        direction TB
        
        subgraph "Domain Services"
            AUTH_DOMAIN[Auth Domain<br/>Pure Business Logic]
            NAV_DOMAIN[Navigation Domain<br/>Coordinate Logic]
            AGUI_DOMAIN[AGUI Domain<br/>Streaming Logic]
        end
        
        subgraph "Infrastructure Services"
            AUTH_CLIENT[Auth API Client<br/>Backend Communication]
            AGUI_CLIENT[AGUI Client<br/>Agentic Communication]
            GRAPHQL_CLIENT[GraphQL Client<br/>Coordinate Queries]
            STORAGE_CLIENT[Storage Client<br/>Browser Persistence]
        end
        
        subgraph "React Integration"
            AUTH_HOOKS[Auth Hooks<br/>React State Bridge]
            NAV_HOOKS[Navigation Hooks<br/>Route Management]
            AGUI_HOOKS[AGUI Hooks<br/>Streaming Bridge]
        end
        
        %% Domain-Hook Integration (Data Flow)
        AUTH_DOMAIN <-.->|State Management| AUTH_HOOKS
        NAV_DOMAIN <-.->|Navigation State| NAV_HOOKS
        AGUI_DOMAIN <-.->|Streaming State| AGUI_HOOKS

        %% Hook-Client Integration (API Calls)
        AUTH_HOOKS <-.->|API Operations| AUTH_CLIENT
        NAV_HOOKS <-.->|GraphQL Operations| GRAPHQL_CLIENT
        AGUI_HOOKS <-.->|Streaming Operations| AGUI_CLIENT

        %% Client Storage Integration
        AUTH_CLIENT <-.->|Session Persistence| STORAGE_CLIENT
    end
    
    subgraph "Agentic Service Integration (Port 8001)"
        direction TB
        
        subgraph "Agent Orchestration"
            ORCH_AGENT[Orchestrator Agent<br/>Pydantic AI Core]
            PERSONA_ROUTER[Persona Router<br/>Dynamic Behavior]
            CONTEXT_PROC[Context Processor<br/>Window Management]
        end
        
        subgraph "Tool Services"
            BIMBA_TOOLS[Bimba Tools<br/>Coordinate Resolution]
            GNOSTIC_TOOLS[Gnostic Tools<br/>Document Intelligence]
            EPISODIC_TOOLS[Episodic Tools<br/>Memory Management]
        end
        
        subgraph "Client Services"
            BACKEND_HTTP[Backend HTTP Client<br/>API Communication]
            MODEL_FACTORY[Model Factory<br/>AI Provider Selection]
            MCP_CLIENT[MCP Client<br/>Tool Protocol]
        end
        
        %% Bidirectional Agent-Infrastructure Flow
        ORCH_AGENT <-.->|Query/Response Cycles| BACKEND_HTTP
        ORCH_AGENT <-.->|Model Selection/Results| MODEL_FACTORY

        %% Tool Integration (Bidirectional Data Flow)
        ORCH_AGENT <-.->|Coordinate Queries/Updates| BIMBA_TOOLS
        ORCH_AGENT <-.->|Document Processing/Storage| GNOSTIC_TOOLS
        ORCH_AGENT <-.->|Memory Formation/Retrieval| EPISODIC_TOOLS

        %% Agent Internal Processing
        ORCH_AGENT --> PERSONA_ROUTER
        ORCH_AGENT --> CONTEXT_PROC

        %% Tool-Backend Data Cycles
        BIMBA_TOOLS <-.->|Coordinate CRUD Operations| BACKEND_HTTP
        GNOSTIC_TOOLS <-.->|Document Intelligence Ops| BACKEND_HTTP
        EPISODIC_TOOLS <-.->|Memory Management Ops| BACKEND_HTTP
    end
    
    subgraph "Backend Service Integration (Port 8000)"
        direction TB
        
        subgraph "API Services"
            REST_API[REST API<br/>User & Auth Operations]
            GRAPHQL_API[GraphQL API<br/>Coordinate Resolution]
            HEALTH_API[Health API<br/>Service Monitoring]
        end
        
        subgraph "Business Services"
            USER_SERVICE[User Service<br/>Profile Management]
            AUTH_SERVICE[Auth Service<br/>JWT & OAuth]
            COORD_SERVICE[Coordinate Service<br/>Bimba Operations]
        end
        
        subgraph "Integration Services"
            LIGHTRAG_SERVICE[LightRAG Service<br/>Document Intelligence]
            GRAPHITI_SERVICE[Graphiti Service<br/>Episodic Memory]
            BILLING_SERVICE[Billing Service<br/>Subscription Management]
        end
        
        REST_API --> USER_SERVICE
        REST_API --> AUTH_SERVICE
        REST_API --> BILLING_SERVICE
        
        GRAPHQL_API --> COORD_SERVICE
        
        LIGHTRAG_SERVICE --> COORD_SERVICE
        GRAPHITI_SERVICE --> COORD_SERVICE
        
        HEALTH_API --> USER_SERVICE
        HEALTH_API --> LIGHTRAG_SERVICE
        HEALTH_API --> GRAPHITI_SERVICE
    end
    
    subgraph "Database Service Layer"
        direction TB
        
        subgraph "Database Clients"
            NEO4J_CLIENT[Neo4j Client<br/>Unified Graph Access]
            MONGO_CLIENT[MongoDB Client<br/>User Data Access]
            REDIS_CLIENT[Redis Client<br/>Cache & Streams]
            QDRANT_CLIENT[Qdrant Client<br/>Vector Operations]
        end
        
        subgraph "Repository Services"
            USER_REPO[User Repository<br/>MongoDB Operations]
            NODE_REPO[Node Repository<br/>Neo4j Operations]
            CACHE_REPO[Cache Repository<br/>Redis Operations]
            VECTOR_REPO[Vector Repository<br/>Qdrant Operations]
        end
        
        %% Database Client Bidirectional Operations
        NEO4J_CLIENT <-.->|Read/Write Graph Data| NODE_REPO
        MONGO_CLIENT <-.->|Read/Write User Data| USER_REPO
        REDIS_CLIENT <-.->|Cache Operations| CACHE_REPO
        QDRANT_CLIENT <-.->|Vector Search/Store| VECTOR_REPO

        %% Service-Repository Data Cycles
        COORD_SERVICE <-.->|Graph Queries/Updates| NODE_REPO
        USER_SERVICE <-.->|User CRUD Operations| USER_REPO
        AUTH_SERVICE <-.->|Session Management| CACHE_REPO
        LIGHTRAG_SERVICE <-.->|Document Vectors| VECTOR_REPO
        GRAPHITI_SERVICE <-.->|Memory Graph Ops| NODE_REPO
    end
    
    subgraph "External Service Integration"
        direction TB
        
        subgraph "Local Databases"
            NEO4J_LOCAL[Neo4j Local<br/>Graph Database]
            QDRANT_LOCAL[Qdrant Local<br/>Vector Database]
        end

        subgraph "Cloud Databases"
            MONGO_ATLAS[MongoDB Atlas<br/>Document Database]
            REDIS_CLOUD[Redis Cloud<br/>Cache Service]
        end
        
        subgraph "AI Providers"
            OPENAI[OpenAI<br/>GPT Models]
            ANTHROPIC[Anthropic<br/>Claude Models]
            GOOGLE_AI[Google AI<br/>Gemini Models]
        end
        
        subgraph "OAuth Providers"
            GOOGLE_OAUTH[Google OAuth<br/>Authentication]
            STRIPE[Stripe<br/>Payment Processing]
        end
        
        %% Database Connection Pools (Bidirectional)
        NEO4J_CLIENT <-.->|Local Connection Pool| NEO4J_LOCAL
        MONGO_CLIENT <-.->|Atlas Connection Pool| MONGO_ATLAS
        REDIS_CLIENT <-.->|Cloud Connection Pool| REDIS_CLOUD
        QDRANT_CLIENT <-.->|Local HTTP API| QDRANT_LOCAL

        %% AI Provider Request/Response Cycles
        MODEL_FACTORY <-.->|API Request/Response| OPENAI
        MODEL_FACTORY <-.->|API Request/Response| ANTHROPIC
        MODEL_FACTORY <-.->|API Request/Response| GOOGLE_AI

        %% External Service Integration Flows
        AUTH_SERVICE <-.->|OAuth Flow/Tokens| GOOGLE_OAUTH
        BILLING_SERVICE <-.->|Payment Processing| STRIPE
    end
    
    %% Cross-Layer Data Flow Patterns

    %% Frontend-Agentic Bidirectional Streaming
    AGUI_CLIENT <-.->|AG-UI Protocol Streaming| ORCH_AGENT
    AGUI_CLIENT <-.->|SSE Request/Response| ORCH_AGENT

    %% Frontend-Backend API Cycles
    AUTH_CLIENT <-.->|Auth API Calls| REST_API
    GRAPHQL_CLIENT <-.->|GraphQL Queries| GRAPHQL_API

    %% Agentic-Backend Service Integration
    BACKEND_HTTP <-.->|REST API Operations| REST_API
    BACKEND_HTTP <-.->|GraphQL Operations| GRAPHQL_API
    BACKEND_HTTP <-.->|LightRAG Intelligence| LIGHTRAG_SERVICE
    BACKEND_HTTP <-.->|Graphiti Memory Ops| GRAPHITI_SERVICE
    
    %% MCP Integration (External Agent Flexibility)
    subgraph "MCP Service Layer"
        direction TB
        BIMBA_MCP[Bimba MCP Server<br/>External Agent Access]
        LIGHTRAG_MCP[LightRAG MCP Server<br/>External Agent Access]
        GRAPHITI_MCP[Graphiti MCP Server<br/>External Agent Access]

        MCP_NOTE[Note: MCPs provide flexible<br/>access for external agents.<br/>Orchestrator uses direct HTTP.]
    end

    %% MCP Alternative Access Patterns (External Agent Flexibility)
    BIMBA_MCP <-.->|Backend API Bridge| COORD_SERVICE
    LIGHTRAG_MCP <-.->|Backend API Bridge| LIGHTRAG_SERVICE
    GRAPHITI_MCP <-.->|Backend API Bridge| GRAPHITI_SERVICE

    %% External Agent MCP Integration (Future Capability)
    MCP_CLIENT <-.->|MCP Protocol - External Agents| BIMBA_MCP
    MCP_CLIENT <-.->|MCP Protocol - External Agents| LIGHTRAG_MCP
    MCP_CLIENT <-.->|MCP Protocol - External Agents| GRAPHITI_MCP
    
    %% Service Health Monitoring
    subgraph "Health Monitoring"
        HEALTH_MONITOR[Health Monitor<br/>Service Status]
        METRICS_COLLECTOR[Metrics Collector<br/>Performance Data]
        LOG_AGGREGATOR[Log Aggregator<br/>Centralized Logging]
    end
    
    HEALTH_API --> HEALTH_MONITOR
    HEALTH_MONITOR --> METRICS_COLLECTOR
    HEALTH_MONITOR --> LOG_AGGREGATOR
    
    classDef frontend fill:#2563eb,stroke:#1e40af,stroke-width:2px,color:#ffffff
    classDef agentic fill:#7c3aed,stroke:#6d28d9,stroke-width:2px,color:#ffffff
    classDef backend fill:#059669,stroke:#047857,stroke-width:2px,color:#ffffff
    classDef database fill:#dc2626,stroke:#b91c1c,stroke-width:2px,color:#ffffff
    classDef external fill:#64748b,stroke:#475569,stroke-width:2px,color:#ffffff
    classDef mcp fill:#f59e0b,stroke:#d97706,stroke-width:2px,color:#ffffff
    classDef monitoring fill:#10b981,stroke:#059669,stroke-width:2px,color:#ffffff
    
    class AUTH_DOMAIN,NAV_DOMAIN,AGUI_DOMAIN,AUTH_CLIENT,AGUI_CLIENT,GRAPHQL_CLIENT,STORAGE_CLIENT,AUTH_HOOKS,NAV_HOOKS,AGUI_HOOKS frontend
    class ORCH_AGENT,PERSONA_ROUTER,CONTEXT_PROC,BIMBA_TOOLS,GNOSTIC_TOOLS,EPISODIC_TOOLS,BACKEND_HTTP,MODEL_FACTORY,MCP_CLIENT agentic
    class REST_API,GRAPHQL_API,HEALTH_API,USER_SERVICE,AUTH_SERVICE,COORD_SERVICE,LIGHTRAG_SERVICE,GRAPHITI_SERVICE,BILLING_SERVICE backend
    class NEO4J_CLIENT,MONGO_CLIENT,REDIS_CLIENT,QDRANT_CLIENT,USER_REPO,NODE_REPO,CACHE_REPO,VECTOR_REPO database
    class NEO4J_LOCAL,QDRANT_LOCAL,MONGO_ATLAS,REDIS_CLOUD,OPENAI,ANTHROPIC,GOOGLE_AI,GOOGLE_OAUTH,STRIPE external
    class BIMBA_MCP,LIGHTRAG_MCP,GRAPHITI_MCP mcp
    class HEALTH_MONITOR,METRICS_COLLECTOR,LOG_AGGREGATOR monitoring
