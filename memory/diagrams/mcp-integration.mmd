graph TB
    %% MCP (Model Context Protocol) Integration Architecture
    
    subgraph "Agentic Layer MCP Orchestration"
        direction TB
        
        subgraph "Pydantic AI Agent"
            AGENT[Orchestrator Agent<br/>Tool Calling Engine]
            TOOL_REGISTRY[Tool Registry<br/>MCP Tool Discovery]
            TOOL_ROUTER[Tool Router<br/>Namespace Routing]
        end
        
        subgraph "MCP Client Integration"
            MCP_CLIENT[MCP Client<br/>Protocol Handler]
            MCP_TRANSPORT[MCP Transport<br/>SSE/HTTP Communication]
            MCP_SCHEMA[MCP Schema<br/>Tool Validation]
        end
        
        AGENT --> TOOL_REGISTRY
        TOOL_REGISTRY --> TOOL_ROUTER
        TOOL_ROUTER --> MCP_CLIENT
        MCP_CLIENT --> MCP_TRANSPORT
        MCP_CLIENT --> MCP_SCHEMA
    end
    
    subgraph "Bimba MCP Server (Canonical Knowledge)"
        direction TB
        
        subgraph "Bimba Server Core"
            BIMBA_SERVER[Bimba MCP Server<br/>Coordinate Protocol]
            BIMBA_HANDLER[Request Handler<br/>Tool Execution]
            BIMBA_VALIDATOR[Parameter Validator<br/>Coordinate Validation]
        end
        
        subgraph "Bimba Tools"
            RESOLVE_COORD[resolve_coordinate<br/>Get node by coordinate]
            SEARCH_COORDS[search_coordinates<br/>Find matching nodes]
            GET_SUBSYSTEM[get_subsystem_coordinates<br/>List subsystem nodes]
            CREATE_NODE[create_bimba_node<br/>Add new coordinate]
            UPDATE_NODE[update_bimba_node<br/>Modify existing node]
        end
        
        subgraph "Bimba Backend Integration"
            BIMBA_GRAPHQL[GraphQL Client<br/>Backend Communication]
            BIMBA_CACHE[Cache Layer<br/>Performance Optimization]
            BIMBA_VALIDATION[Business Logic<br/>Coordinate Rules]
        end
        
        BIMBA_SERVER --> BIMBA_HANDLER
        BIMBA_HANDLER --> BIMBA_VALIDATOR
        BIMBA_VALIDATOR --> RESOLVE_COORD
        BIMBA_VALIDATOR --> SEARCH_COORDS
        BIMBA_VALIDATOR --> GET_SUBSYSTEM
        BIMBA_VALIDATOR --> CREATE_NODE
        BIMBA_VALIDATOR --> UPDATE_NODE
        
        RESOLVE_COORD --> BIMBA_GRAPHQL
        SEARCH_COORDS --> BIMBA_GRAPHQL
        GET_SUBSYSTEM --> BIMBA_GRAPHQL
        CREATE_NODE --> BIMBA_GRAPHQL
        UPDATE_NODE --> BIMBA_GRAPHQL
        
        BIMBA_GRAPHQL --> BIMBA_CACHE
        BIMBA_GRAPHQL --> BIMBA_VALIDATION
    end
    
    subgraph "LightRAG MCP Server (Document Intelligence)"
        direction TB
        
        subgraph "LightRAG Server Core"
            LIGHT_SERVER[LightRAG MCP Server<br/>Document Protocol]
            LIGHT_HANDLER[Request Handler<br/>Intelligence Operations]
            LIGHT_VALIDATOR[Parameter Validator<br/>Document Validation]
        end
        
        subgraph "LightRAG Tools"
            INGEST_DOC[lightrag_ingest_document<br/>Process documents]
            SEARCH_DOCS[lightrag_search_documents<br/>Semantic search]
            GET_CONTEXT[lightrag_get_coordinate_context<br/>Contextual retrieval]
            HEALTH_CHECK[lightrag_health_check<br/>Service status]
            WORKSPACE_INFO[lightrag_workspace_info<br/>Configuration details]
        end
        
        subgraph "LightRAG Backend Integration"
            LIGHT_API[LightRAG API Client<br/>Backend Communication]
            LIGHT_CACHE[Document Cache<br/>Performance Layer]
            LIGHT_PROCESSING[Document Processing<br/>Intelligence Pipeline]
        end
        
        LIGHT_SERVER --> LIGHT_HANDLER
        LIGHT_HANDLER --> LIGHT_VALIDATOR
        LIGHT_VALIDATOR --> INGEST_DOC
        LIGHT_VALIDATOR --> SEARCH_DOCS
        LIGHT_VALIDATOR --> GET_CONTEXT
        LIGHT_VALIDATOR --> HEALTH_CHECK
        LIGHT_VALIDATOR --> WORKSPACE_INFO
        
        INGEST_DOC --> LIGHT_API
        SEARCH_DOCS --> LIGHT_API
        GET_CONTEXT --> LIGHT_API
        HEALTH_CHECK --> LIGHT_API
        WORKSPACE_INFO --> LIGHT_API
        
        LIGHT_API --> LIGHT_CACHE
        LIGHT_API --> LIGHT_PROCESSING
    end
    
    subgraph "Graphiti MCP Server (Episodic Memory)"
        direction TB
        
        subgraph "Graphiti Server Core"
            GRAPH_SERVER[Graphiti MCP Server<br/>Memory Protocol]
            GRAPH_HANDLER[Request Handler<br/>Episode Operations]
            GRAPH_VALIDATOR[Parameter Validator<br/>Memory Validation]
        end
        
        subgraph "Graphiti Tools"
            CREATE_EPISODE[create_episode<br/>Store memory]
            SEARCH_EPISODES[search_episodes<br/>Temporal search]
            GET_SESSION[get_session_episodes<br/>Session continuity]
            CREATE_COMMUNITY[create_community<br/>Memory clustering]
            GET_RUMINATIONS[get_agent_ruminations<br/>Agent memory]
        end
        
        subgraph "Graphiti Backend Integration"
            GRAPH_API[Graphiti API Client<br/>Backend Communication]
            GRAPH_CACHE[Memory Cache<br/>Session Optimization]
            GRAPH_PROCESSING[Memory Processing<br/>Temporal Analysis]
        end
        
        GRAPH_SERVER --> GRAPH_HANDLER
        GRAPH_HANDLER --> GRAPH_VALIDATOR
        GRAPH_VALIDATOR --> CREATE_EPISODE
        GRAPH_VALIDATOR --> SEARCH_EPISODES
        GRAPH_VALIDATOR --> GET_SESSION
        GRAPH_VALIDATOR --> CREATE_COMMUNITY
        GRAPH_VALIDATOR --> GET_RUMINATIONS
        
        CREATE_EPISODE --> GRAPH_API
        SEARCH_EPISODES --> GRAPH_API
        GET_SESSION --> GRAPH_API
        CREATE_COMMUNITY --> GRAPH_API
        GET_RUMINATIONS --> GRAPH_API
        
        GRAPH_API --> GRAPH_CACHE
        GRAPH_API --> GRAPH_PROCESSING
    end
    
    subgraph "Backend Service Layer"
        direction TB
        
        subgraph "Database Constellation"
            NEO4J[Neo4j Aura<br/>Unified Graph Database]
            MONGODB[MongoDB Atlas<br/>User Data]
            REDIS[Redis Cloud<br/>Cache & Streams]
            QDRANT[Qdrant<br/>Vector Database]
        end
        
        subgraph "Service APIs"
            COORD_API[Coordinate API<br/>GraphQL Endpoint]
            LIGHT_BACKEND[LightRAG Service<br/>Document Intelligence]
            GRAPH_BACKEND[Graphiti Service<br/>Episodic Memory]
        end
        
        COORD_API --> NEO4J
        LIGHT_BACKEND --> NEO4J
        LIGHT_BACKEND --> QDRANT
        GRAPH_BACKEND --> NEO4J
        
        COORD_API --> REDIS
        LIGHT_BACKEND --> REDIS
        GRAPH_BACKEND --> REDIS
    end
    
    %% MCP Protocol Connections
    MCP_TRANSPORT -.->|MCP Protocol| BIMBA_SERVER
    MCP_TRANSPORT -.->|MCP Protocol| LIGHT_SERVER
    MCP_TRANSPORT -.->|MCP Protocol| GRAPH_SERVER
    
    %% Backend API Connections
    BIMBA_GRAPHQL -.->|GraphQL| COORD_API
    LIGHT_API -.->|HTTP API| LIGHT_BACKEND
    GRAPH_API -.->|HTTP API| GRAPH_BACKEND
    
    %% Tool Routing
    TOOL_ROUTER -.->|Bimba Namespace| BIMBA_SERVER
    TOOL_ROUTER -.->|Gnostic Namespace| LIGHT_SERVER
    TOOL_ROUTER -.->|Episodic Namespace| GRAPH_SERVER
    
    %% Cross-namespace Integration
    subgraph "Cross-namespace Coordination"
        COORD_SYNC[Coordinate Synchronization<br/>Cross-tool Context]
        CONTEXT_FRAME[Context Frame Activation<br/>Multi-tool Workflows]
        MEMORY_SYNTHESIS[Memory Synthesis<br/>Cross-namespace Learning]
    end
    
    BIMBA_SERVER -.->|Coordinate Context| COORD_SYNC
    LIGHT_SERVER -.->|Document Context| COORD_SYNC
    GRAPH_SERVER -.->|Memory Context| COORD_SYNC
    
    COORD_SYNC --> CONTEXT_FRAME
    CONTEXT_FRAME --> MEMORY_SYNTHESIS
    
    classDef agent fill:#7c3aed,stroke:#6d28d9,stroke-width:2px,color:#ffffff
    classDef mcp fill:#dc2626,stroke:#b91c1c,stroke-width:2px,color:#ffffff
    classDef tool fill:#059669,stroke:#047857,stroke-width:2px,color:#ffffff
    classDef backend fill:#3b82f6,stroke:#2563eb,stroke-width:2px,color:#ffffff
    classDef database fill:#64748b,stroke:#475569,stroke-width:2px,color:#ffffff
    classDef integration fill:#f59e0b,stroke:#d97706,stroke-width:2px,color:#ffffff
    
    class AGENT,TOOL_REGISTRY,TOOL_ROUTER,MCP_CLIENT,MCP_TRANSPORT,MCP_SCHEMA agent
    class BIMBA_SERVER,BIMBA_HANDLER,BIMBA_VALIDATOR,LIGHT_SERVER,LIGHT_HANDLER,LIGHT_VALIDATOR,GRAPH_SERVER,GRAPH_HANDLER,GRAPH_VALIDATOR mcp
    class RESOLVE_COORD,SEARCH_COORDS,GET_SUBSYSTEM,CREATE_NODE,UPDATE_NODE,INGEST_DOC,SEARCH_DOCS,GET_CONTEXT,HEALTH_CHECK,WORKSPACE_INFO,CREATE_EPISODE,SEARCH_EPISODES,GET_SESSION,CREATE_COMMUNITY,GET_RUMINATIONS tool
    class COORD_API,LIGHT_BACKEND,GRAPH_BACKEND,BIMBA_GRAPHQL,LIGHT_API,GRAPH_API backend
    class NEO4J,MONGODB,REDIS,QDRANT database
    class COORD_SYNC,CONTEXT_FRAME,MEMORY_SYNTHESIS,BIMBA_CACHE,LIGHT_CACHE,GRAPH_CACHE integration
