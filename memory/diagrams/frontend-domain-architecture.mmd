        subgraph "AGUI Components"
            CHAT_INTERFACE[ChatInterface<br/>Conversation UI]
            STREAM_DISPLAY[StreamDisplay<br/>Real-time Updates]
            MODEL_SELECTOR[ModelSelector<br/>AI Model Selection]
            RESPONSE_VIEWER[ResponseViewer<br/>Agent Output]
        end
        
        AUTH_PROVIDER --> SIGN_IN
        AUTH_PROVIDER --> PROFILE_CARD
        AUTH_PROVIDER --> ROUTE_GUARD
        
        NAV_BAR --> SUBSYSTEM_NAV
        NAV_BAR --> BREADCRUMB
        NAV_BAR --> HEXAGON_NAV
        
        CHAT_INTERFACE --> STREAM_DISPLAY
        CHAT_INTERFACE --> MODEL_SELECTOR
        CHAT_INTERFACE --> RESPONSE_VIEWER
    end
    
    subgraph "Infrastructure Layer"
        direction TB
        
        subgraph "API Clients"
            AUTH_CLIENT[Auth API Client<br/>Backend Communication]
            AGUI_CLIENT[AGUI API Client<br/>Agentic Communication]
            GRAPHQL_CLIENT[GraphQL Client<br/>Coordinate Queries]
        end
        
        subgraph "Storage Adapters"
            SESSION_STORAGE[Session Storage<br/>Browser Storage]
            LOCAL_STORAGE[Local Storage<br/>Persistent Data]
            CACHE_ADAPTER[Cache Adapter<br/>Query Caching]
        end
        
        subgraph "External Integrations"
            GOOGLE_OAUTH[Google OAuth<br/>Authentication Provider]
            STRIPE_CLIENT[Stripe Client<br/>Payment Processing]
            ANALYTICS[Analytics<br/>Usage Tracking]
        end
        
        AUTH_CLIENT --> SESSION_STORAGE
        AGUI_CLIENT --> CACHE_ADAPTER
        GRAPHQL_CLIENT --> CACHE_ADAPTER
        
        SESSION_STORAGE --> LOCAL_STORAGE
        
        GOOGLE_OAUTH --> AUTH_CLIENT
        STRIPE_CLIENT --> AUTH_CLIENT
    end
    
    %% Layer Dependencies (Decoupled Domain Pattern)
    %% Infrastructure → Domain → Hooks → Components → App Structure

    %% Infrastructure feeds Domain Logic
    AUTH_CLIENT --> AUTH_LOGIC
    GRAPHQL_CLIENT --> NAV_LOGIC
    GRAPHQL_CLIENT --> COORD_LOGIC
    AGUI_CLIENT --> AGUI_LOGIC

    %% Domain Logic feeds Hooks
    AUTH_LOGIC --> USE_AUTH
    NAV_LOGIC --> USE_NAV
    COORD_LOGIC --> USE_COORDINATE
    AGUI_LOGIC --> USE_AGUI

    %% Hooks feed Components
    USE_AUTH --> AUTH_PROVIDER
    USE_NAV --> NAV_BAR
    USE_COORDINATE --> SUBSYSTEM_NAV
    USE_AGUI --> CHAT_INTERFACE
    
