            AUTH_PROVIDER[UnifiedAuthProvider<br/>Context Provider]
            SIGN_IN[SignInForm<br/>Authentication UI]
            PROFILE_CARD[ProfileCard<br/>User Display]
            ROUTE_GUARD[RouteGuard<br/>Access Protection]
