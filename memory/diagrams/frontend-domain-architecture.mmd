        USE_AUTH --> USE_OAUTH
        USE_AUTH --> USE_SESSION
        USE_AUTH --> USE_PROFILE

        USE_NAV --> USE_SUBSYSTEM
        USE_NAV --> USE_BREADCRUMB

        USE_COORDINATE --> USE_POSITION
        USE_COORDINATE --> USE_BIMBA

        USE_AGUI --> USE_STREAM
        USE_AGUI --> USE_CHAT
        USE_AGUI --> USE_MODELS
    end
    
    subgraph "Component Layer (Appliances)"
