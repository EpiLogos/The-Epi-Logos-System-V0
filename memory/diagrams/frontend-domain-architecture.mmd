graph TB
    %% Frontend Domain-Driven Architecture
    
    subgraph "Next.js 15 Application (Port 3000)"
        direction TB
        APP[app/<br/>App Router]
        
        subgraph "Route Structure"
            HOME["/<br/>Landing Page / Overture"]
            AUTH["/auth<br/>Authentication"]
            ACCOUNT["/account<br/>User Dashboard"]
            SYSTEM["/system<br/>Application Hub"]
        end

        subgraph "Six Subsystem Routes"
            ANUTTARA["/system/anuttara<br/>Metaphysical OS"]
            PARAMASIVA["/system/paramasiva<br/>Logical Foundation"]
            PARASHAKTI["/system/parashakti<br/>Vibrational Engine"]
            MAHAMAYA["/system/mahamaya<br/>Transcription Engine"]
            NARA["/system/nara<br/>Personal Engine"]
            EPII["/system/epii<br/>Meta-Cognitive Framework"]
        end
        
        subgraph "Layout System"
            ROOT_LAYOUT[Root Layout<br/>Global Providers]
            AUTH_LAYOUT[Auth Layout<br/>Authentication Flow]
            SYSTEM_LAYOUT[System Layout<br/>Navigation Context]
        end
        
        APP --> HOME
        APP --> AUTH
        APP --> ACCOUNT
        APP --> SYSTEM

        SYSTEM --> ANUTTARA
        SYSTEM --> PARAMASIVA
        SYSTEM --> PARASHAKTI
        SYSTEM --> MAHAMAYA
        SYSTEM --> NARA
        SYSTEM --> EPII
        
        ROOT_LAYOUT --> AUTH_LAYOUT
        ROOT_LAYOUT --> SYSTEM_LAYOUT
    end
    
    subgraph "Domain Layer (Power Plant)"
        direction TB

        subgraph "Auth Domain"
            AUTH_TYPES[Auth Types<br/>User, AuthState, Tokens]
            AUTH_LOGIC[Auth Logic<br/>Pure Functions]
            AUTH_VALIDATION[Auth Validation<br/>Business Rules]
            AUTH_SESSION[Session Management<br/>State Transitions]
        end

        subgraph "Navigation Domain"
            NAV_TYPES[Navigation Types<br/>Route, Breadcrumb]
            NAV_LOGIC[Navigation Logic<br/>Hexagonal Navigation]
            NAV_VALIDATION[Navigation Validation<br/>Access Control]
            NAV_CONTEXT[Context Management<br/>Navigation State]
        end

        subgraph "Coordinate Domain"
            COORD_TYPES[Coordinate Types<br/>Bimba, Subsystem]
            COORD_LOGIC[Coordinate Logic<br/>Position Resolution]
            COORD_VALIDATION[Coordinate Validation<br/>Valid Coordinates]
            COORD_DISPLAY[Display Logic<br/>Persistent UI]
        end

        subgraph "AGUI Domain"
            AGUI_TYPES[AGUI Types<br/>Message, Stream, Event]
            AGUI_LOGIC[AGUI Logic<br/>Protocol Handling]
            AGUI_VALIDATION[AGUI Validation<br/>Message Validation]
            AGUI_STREAMING[Streaming Logic<br/>SSE Management]
        end
        
        %% Internal Domain Logic Flow (within each domain)
        AUTH_TYPES --> AUTH_LOGIC
        AUTH_LOGIC --> AUTH_VALIDATION
        AUTH_VALIDATION --> AUTH_SESSION

        NAV_TYPES --> NAV_LOGIC
        NAV_LOGIC --> NAV_VALIDATION
        NAV_VALIDATION --> NAV_CONTEXT

        COORD_TYPES --> COORD_LOGIC
        COORD_LOGIC --> COORD_VALIDATION
        COORD_VALIDATION --> COORD_DISPLAY

        AGUI_TYPES --> AGUI_LOGIC
        AGUI_LOGIC --> AGUI_VALIDATION
        AGUI_VALIDATION --> AGUI_STREAMING
    end
    
    subgraph "Orchestration Layer (Wall Sockets)"
        direction TB
        
        subgraph "Auth Hooks"
            USE_AUTH[useAuth<br/>Primary Auth Hook]
            USE_OAUTH[useOAuth<br/>OAuth Flow Hook]
            USE_SESSION[useSession<br/>Session Hook]
            USE_PROFILE[useProfile<br/>Profile Hook]
        end
        
        subgraph "Navigation Hooks"
            USE_NAV[useNavigation<br/>Primary Nav Hook]
            USE_SUBSYSTEM[useSubsystem<br/>Subsystem Hook]
            USE_BREADCRUMB[useBreadcrumb<br/>Breadcrumb Hook]
