            USE_AGUI[useAGUI<br/>Primary AGUI Hook]
            USE_STREAM[useStream<br/>Streaming Hook]
            USE_CHAT[useChat<br/>Chat Hook]
            USE_MODELS[useModels<br/>Model Selection Hook]
