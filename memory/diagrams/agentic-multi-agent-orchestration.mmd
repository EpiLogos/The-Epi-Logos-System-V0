     CONTEXT_LINEAGES:::data
     CONTEXT_PACKAGE:::data
     WISDOM_PACKETS:::data
     BIMBA_TOOL:::tool
     LIGHTRAG_TOOL:::tool
     GRAPHITI_TOOL:::tool
     REDIS_TOOL:::tool
     TOOLS_0:::tool
