// VERIFICATION QUERY
// ================================================================

// Verify all updates were applied
MATCH (root:BimbaNode {bimbaCoordinate: "#"})
MATCH (epii:BimbaNode {bimbaCoordinate: "#5"})
MATCH (epii_agent:BimbaNode {bimbaCoordinate: "#5-4.5"})
MATCH (logos_cycle:BimbaNode {bimbaCoordinate: "#5-5"})
MATCH (dialogos:BimbaNode {bimbaCoordinate: "#5-5-2"})
RETURN
  root.bimbaCoordinate AS root_coord,
  root.epii_etymological_archaeology_paradigm IS NOT NULL AS root_has_archaeology,
  root.epii_soteriology_qua_recognition IS NOT NULL AS root_has_soteriology,
  epii.bimbaCoordinate AS epii_coord,
  epii.etymologicalArchaeology_method IS NOT NULL AS epii_has_method,
  epii.sixfold_protocol_embodiment IS NOT NULL AS epii_has_protocol,
  epii.conScire_dialogical_structure IS NOT NULL AS epii_has_conscire,
  epii.paradox_as_portal_canonical IS NOT NULL AS epii_has_paradox,
  epii_agent.bimbaCoordinate AS agent_coord,
  epii_agent.f_protocol_stage_0_recognition IS NOT NULL AS agent_has_stage0,
  epii_agent.f_protocol_stage_1_contemplation IS NOT NULL AS agent_has_stage1,
  epii_agent.f_protocol_stage_2_community_formation IS NOT NULL AS agent_has_stage2,
  epii_agent.f_protocol_stage_3_canonical_scouring IS NOT NULL AS agent_has_stage3,
  epii_agent.f_protocol_stage_4_insight_generation_recursive_nesting IS NOT NULL AS agent_has_stage4,
  epii_agent.f_protocol_stage_5_gnostic_sedimentation IS NOT NULL AS agent_has_stage5,
  epii_agent.f_scent_following_method IS NOT NULL AS agent_has_scent_method,
  logos_cycle.bimbaCoordinate AS logos_coord,
  logos_cycle.protocol_as_constitutional_activity IS NOT NULL AS logos_has_protocol,
  dialogos.bimbaCoordinate AS dialogos_coord,
  dialogos.communityFormation_stage IS NOT NULL AS dialogos_has_community;
