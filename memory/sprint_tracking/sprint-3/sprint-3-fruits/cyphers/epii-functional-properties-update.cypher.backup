SET epii.f_etymological_archaeology_capability = {
  description: "Multi-lens etymological analysis revealing archetypal patterns encoded in language itself",
  method: "episodic_lens_exploration → mef_validation → bimba_crystallization",
  episodic_namespace: "graphiti_temporal_graph",
  lens_storage: "episodic://etymology-lenses",
