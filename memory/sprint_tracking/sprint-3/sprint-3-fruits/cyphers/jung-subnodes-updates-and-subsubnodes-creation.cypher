    ],
    p.resonances = [
        'Gnosticism Basilides Valentinus - early Gnostic teachers Jung channeled',
        'Taoism Tao Te Ching - unus mundus Western equivalent of Tao',
        'Alchemy mysterium coniunctionis - ultimate union goal',
