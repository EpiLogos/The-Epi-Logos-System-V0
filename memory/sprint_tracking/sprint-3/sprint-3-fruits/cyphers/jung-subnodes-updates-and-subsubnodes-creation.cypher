    p.qlPosition = 5,
    p.qlCategory = 'Jnana-Integration',
    p.lastUpdated = datetime();

// ============================================================================
// PART 2: CREATE 36 SUBNODES PROGRAMMATICALLY
// Creates all #4.4.3-X-Y nodes (6 positions × 6 subnodes = 36 total)
// Links each to parent with HAS_INTERNAL_COMPONENT relationship
// ============================================================================

// Create all 36 subnodes with basic properties and link to parents
UNWIND [
    // Position 0 subnodes
    {coord: '#4.4.3-0-0', parent: '#4.4.3-0', subsystem: 4},
    {coord: '#4.4.3-0-1', parent: '#4.4.3-0', subsystem: 4},
    {coord: '#4.4.3-0-2', parent: '#4.4.3-0', subsystem: 4},
    {coord: '#4.4.3-0-3', parent: '#4.4.3-0', subsystem: 4},
    {coord: '#4.4.3-0-4', parent: '#4.4.3-0', subsystem: 4},
    {coord: '#4.4.3-0-5', parent: '#4.4.3-0', subsystem: 4},
    
    // Position 1 subnodes
    {coord: '#4.4.3-1-0', parent: '#4.4.3-1', subsystem: 4},
    {coord: '#4.4.3-1-1', parent: '#4.4.3-1', subsystem: 4},
    {coord: '#4.4.3-1-2', parent: '#4.4.3-1', subsystem: 4},
    {coord: '#4.4.3-1-3', parent: '#4.4.3-1', subsystem: 4},
    {coord: '#4.4.3-1-4', parent: '#4.4.3-1', subsystem: 4},
    {coord: '#4.4.3-1-5', parent: '#4.4.3-1', subsystem: 4},
    
    // Position 2 subnodes
    {coord: '#4.4.3-2-0', parent: '#4.4.3-2', subsystem: 4},
    {coord: '#4.4.3-2-1', parent: '#4.4.3-2', subsystem: 4},
    {coord: '#4.4.3-2-2', parent: '#4.4.3-2', subsystem: 4},
    {coord: '#4.4.3-2-3', parent: '#4.4.3-2', subsystem: 4},
    {coord: '#4.4.3-2-4', parent: '#4.4.3-2', subsystem: 4},
    {coord: '#4.4.3-2-5', parent: '#4.4.3-2', subsystem: 4},
    
    // Position 3 subnodes
    {coord: '#4.4.3-3-0', parent: '#4.4.3-3', subsystem: 4},
    {coord: '#4.4.3-3-1', parent: '#4.4.3-3', subsystem: 4},
    {coord: '#4.4.3-3-2', parent: '#4.4.3-3', subsystem: 4},
    {coord: '#4.4.3-3-3', parent: '#4.4.3-3', subsystem: 4},
    {coord: '#4.4.3-3-4', parent: '#4.4.3-3', subsystem: 4},
    {coord: '#4.4.3-3-5', parent: '#4.4.3-3', subsystem: 4},
    
    // Position 4 subnodes
    {coord: '#4.4.3-4.0', parent: '#4.4.3-4', subsystem: 4},
    {coord: '#4.4.3-4.1', parent: '#4.4.3-4', subsystem: 4},
    {coord: '#4.4.3-4.2', parent: '#4.4.3-4', subsystem: 4},
    {coord: '#4.4.3-4.3', parent: '#4.4.3-4', subsystem: 4},
    {coord: '#4.4.3-4.4', parent: '#4.4.3-4', subsystem: 4},
    {coord: '#4.4.3-4.5', parent: '#4.4.3-4', subsystem: 4},
    
    // Position 5 subnodes
    {coord: '#4.4.3-5-0', parent: '#4.4.3-5', subsystem: 4},
    {coord: '#4.4.3-5-1', parent: '#4.4.3-5', subsystem: 4},
    {coord: '#4.4.3-5-2', parent: '#4.4.3-5', subsystem: 4},
    {coord: '#4.4.3-5-3', parent: '#4.4.3-5', subsystem: 4},
    {coord: '#4.4.3-5-4', parent: '#4.4.3-5', subsystem: 4},
    {coord: '#4.4.3-5-5', parent: '#4.4.3-5', subsystem: 4}
] AS node

MERGE (child:BimbaNode:JungianNode {bimbaCoordinate: node.coord})
ON CREATE SET 
    child.subsystem = node.subsystem,
    child.created = datetime()

WITH node, child
MATCH (parent:BimbaNode {bimbaCoordinate: node.parent})
MERGE (parent)-[:HAS_INTERNAL_COMPONENT]->(child)

RETURN count(*) as nodesCreated;

// ============================================================================
// VERIFICATION QUERY
// ============================================================================

// Verify all 6 parents and 36 children exist with proper relationships
MATCH (parent:BimbaNode) 
WHERE parent.bimbaCoordinate IN [
    '#4.4.3-0', '#4.4.3-1', '#4.4.3-2', 
    '#4.4.3-3', '#4.4.3-4', '#4.4.3-5'
]
OPTIONAL MATCH (parent)-[:HAS_INTERNAL_COMPONENT]->(child)
RETURN 
    parent.bimbaCoordinate as parent,
    parent.name as parentName,
    count(child) as childCount,
    collect(child.bimbaCoordinate) as children
ORDER BY parent;